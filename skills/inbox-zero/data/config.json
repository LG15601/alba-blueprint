{
  "version": "1.0.0",
  "agent": "inbox-zero",
  "description": "Email Operations Manager — Orchestra Intelligence",

  "accounts": [
    {
      "email": "ludovic.goutel@gmail.com",
      "type": "personal",
      "priority": "high",
      "label_prefix": "alba"
    },
    {
