# ===========================================
# ALBA Blueprint — Environment Variables
# Copy to ~/.alba/.env and fill in your keys
# ===========================================

# --- Anthropic (required) ---
# Login via: claude login
# Plan: Pro ($20/mo) or Max ($100-200/mo)

# --- Google Workspace (required) ---
# Auth via: gws auth login
# Covers: Gmail, Calendar, Drive, Sheets, Docs

# --- Twitter/X (optional) ---
# Get from: developer.x.com
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# --- ElevenLabs (optional) ---
# Get from: elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# --- Brave Search (optional) ---
# Get from: brave.com/search/api/
BRAVE_API_KEY=

# --- Exa (optional) ---
# Get from: exa.ai
EXA_API_KEY=

# --- Supabase (per project) ---
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# --- Vercel (per project) ---
VERCEL_TOKEN=

# --- VPS Sync (optional) ---
VPS_HOST=100.95.185.71
VPS_USER=clawdbot
VPS_SSH_KEY=~/.ssh/id_ed25519
